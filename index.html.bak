<input class="w-full bg-transparent border-none focus:ring-0 text-body-md font-body-md" placeholder="Cari jasa: Tukang Kebun, Listrik..." type="text"/>
</div>
<div class="hidden md:flex flex-1 items-center px-lg">
<span class="material-symbols-outlined text-outline mr-sm">location_on</span>
<input class="w-full bg-transparent border-none focus:ring-0 text-body-md font-body-md" placeholder="Lokasi Anda" type="text"/>
</div>
<button class="bg-primary text-on-primary px-2xl py-md rounded-full font-bold flex items-center gap-sm hover:opacity-90 active:scale-95 transition-all">
                            Cari
                        </button>
</div>
</div>
</div>
