<main>
<!-- Hero Section -->
<section class="hero-gradient min-h-[85vh] flex flex-col items-center justify-center text-center px-xl py-4xl relative overflow-hidden">
<div class="max-w-4xl mx-auto space-y-xl z-10">
<h1 class="font-headline-lg text-headline-lg md:text-display text-forest-deep leading-tight">
                    Kerja Lebih Mudah,<br class="hidden md:block"/> Hidup Lebih Baik
                </h1>
<p class="font-body-lg text-body-lg text-text-mid max-w-2xl mx-auto">
                    Hubungkan kebutuhan Anda dengan pekerja serabutan terpercaya di sekitar Anda. Solusi praktis untuk setiap sudut rumah dan bisnis Anda.
                </p>
<!-- Floating Search Bar -->
<div class="mt-2xl max-w-3xl mx-auto">
